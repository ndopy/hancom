.vscode
.idea
node_modules/

# YOLO 모델 가중치 (공개 사전학습 파일, 재다운로드 가능)
*.pt

# YOLO 추론 결과 (자동 생성 디렉토리)
**/runs/

# OpenVINO 변환 모델 (model.export()로 재생성 가능)
**/*_openvino_model/

# 12_data 실습 이미지 (카메라 촬영본 · 증강 결과물)
hancom/12_data/**/*.jpg
hancom/12_data/**/*.jpeg
hancom/12_data/**/*.png

# 환경변수 파일 (API 키 등 민감 정보)
.env
**/.env

# Python 바이트코드 캐시
__pycache__/
**/__pycache__/

# Gradio 실행 시 자동 생성되는 런타임 파일 (인증서, flagged 데이터)
**/.gradio/

